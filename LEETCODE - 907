class Solution {
public:
    int sumSubarrayMins(vector<int>& arr) {
        int n = arr.size();
        long sum = 0, MOD = 1e9+7;
        stack<int> st;

        for (int i = 0; i <= n; i++) {
            while (!st.empty() && (i == n || arr[st.top()] >= arr[i])) {
                int m = st.top(); st.pop();
                sum = (sum + (long)arr[m] * (m - (st.empty()?-1:st.top())) * (i - m)) % MOD;
            }
            st.push(i);
        }
        return sum;
    }
};
